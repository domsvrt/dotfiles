#!/bin/sh
set -eu

status() {
  if ! command -v nmcli >/dev/null 2>&1; then
    printf '{"text":"󰖪 Net","class":"missing","tooltip":"nmcli not found"}\n'
    exit 0
  fi

  if [ "$(nmcli -t -f WIFI g 2>/dev/null || printf disabled)" = "disabled" ]; then
    printf '{"text":"󰖪","class":"off","tooltip":"Wi-Fi disabled - right-click to enable"}\n'
    exit 0
  fi

  ssid="$(nmcli -t -f DEVICE,TYPE,STATE,CONNECTION dev status 2>/dev/null | awk -F: '$2=="wifi" && $3=="connected"{print $4; exit}')"
  signal="$(nmcli -t -f IN-USE,SIGNAL dev wifi list 2>/dev/null | awk -F: '$1=="*"{print $2; exit}')"
  if [ -n "$ssid" ]; then
    [ -n "$ssid" ] || ssid="Hidden"
    [ -n "$signal" ] || signal="?"
    printf '{"text":"󰤨 %s%%","class":"on","tooltip":"Connected: %s (%s%%) - click to change network"}\n' "$signal" "$ssid" "$signal"
  else
    printf '{"text":"󰤯","class":"off","tooltip":"Not connected - click to choose a network"}\n'
  fi
}

menu() {
  if ! command -v nmcli >/dev/null 2>&1 || ! command -v wofi >/dev/null 2>&1; then
    exit 1
  fi

  # Do nothing on left-click when Wi-Fi radio is off.
  [ "$(nmcli -t -f WIFI g 2>/dev/null || printf disabled)" = "enabled" ] || exit 0

  nmcli dev wifi rescan >/dev/null 2>&1 || true

  wifi_dev="$(nmcli -t -f DEVICE,TYPE dev status | awk -F: '$2=="wifi"{print $1; exit}')"
  [ -n "$wifi_dev" ] || exit 1

  chosen="$(nmcli --colors no -f SSID,SIGNAL,SECURITY,BSSID,IN-USE dev wifi list ifname "$wifi_dev" \
    | sed '1d' \
    | sed '/^[[:space:]]*$/d' \
    | awk '!seen[$0]++' \
    | wofi --dmenu --prompt "Wi-Fi networks" --lines 18)" || exit 0

  [ -n "$chosen" ] || exit 0
  bssid="$(printf '%s\n' "$chosen" | grep -Eo '([[:xdigit:]]{2}:){5}[[:xdigit:]]{2}' | head -n1)"
  [ -n "$bssid" ] || exit 0

  ssid="$(nmcli -t -f BSSID,SSID dev wifi list ifname "$wifi_dev" | awk -F: -v b="$bssid" 'substr($0,1,17)==b {print substr($0,19); exit}')"
  [ -n "$ssid" ] || ssid="$(printf '%s\n' "$chosen" | sed -E 's/[[:space:]]+([0-9]{1,3})[[:space:]]+.*$//' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"

  nmcli --wait 25 dev wifi connect "$ssid" bssid "$bssid" ifname "$wifi_dev" >/dev/null 2>&1 || {
    pass="$(printf '\n' | wofi --dmenu --password --prompt "Password for ${ssid:-$bssid}")" || exit 0
    [ -n "$pass" ] || exit 0
    # Remove stale profile for the selected SSID so a wrong saved password does not override input.
    nmcli connection delete "$ssid" >/dev/null 2>&1 || true
    nmcli --wait 25 dev wifi connect "$ssid" password "$pass" bssid "$bssid" ifname "$wifi_dev" >/dev/null 2>&1 || exit 1
  }

  # Ensure target AP became active; if not, fail so status stays accurate.
  active_bssid="$(nmcli -t -f IN-USE,BSSID dev wifi list ifname "$wifi_dev" | awk -F: '$1=="*"{print $2; exit}')"
  [ "$active_bssid" = "$bssid" ] || exit 1
}

toggle() {
  [ "$(nmcli -t -f WIFI g 2>/dev/null || printf disabled)" = "enabled" ] \
    && nmcli radio wifi off >/dev/null 2>&1 \
    || nmcli radio wifi on >/dev/null 2>&1
}

disconnect() {
  nmcli dev disconnect wlan0 >/dev/null 2>&1 \
    || nmcli -t -f DEVICE,TYPE,STATE dev status | awk -F: '$2=="wifi" && $3=="connected"{print $1; exit}' | xargs -r nmcli dev disconnect >/dev/null 2>&1 \
    || true
}

rescan() {
  nmcli dev wifi rescan >/dev/null 2>&1 || true
}

case "${1:-status}" in
  status) status ;;
  menu) menu ;;
  toggle) toggle ;;
  disconnect) disconnect ;;
  rescan) rescan ;;
  *) exit 2 ;;
esac
